{
  "name": "@bragfast/mcp-server",
  "version": "0.3.2",
  "description": "MCP server for Bragfast — generate release images and videos from Claude",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bragfast-mcp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "serve": "node dist/serve.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "bragfast",
    "release",
    "images",
    "video"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rob-vb/bragfast-mcp"
  },
  "license": "MIT",
  "files": [
    "dist",
    "manifest.json"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^5.2.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
